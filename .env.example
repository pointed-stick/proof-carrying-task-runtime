# Example environment file for the task_runtime project.
# Copy to ".env" in this directory and fill in your values.
#
# This .env is loaded by the example scripts in task_runtime/examples/ via a
# tiny loader (`_load_api_key`) that reads the parent of the task_runtime
# package and sets OPENAI_API_KEY in the process environment.

# Required for any demo that makes live LLM calls.
# The loader accepts either `API_KEY` (preferred for local .env files) or
# `OPENAI_API_KEY` (the standard openai-python variable name).
API_KEY=sk-your-openai-api-key-here

# Optional: override the LLM model used by the runtime.
# Default: gpt-4o-mini
# TASK_RUNTIME_MODEL=gpt-4o-mini

# Optional: override the bundled Wikipedia cache directory.
# Default: task_runtime/wiki_cache/  (resolved relative to wiki_tool.py)
# Set to an empty directory to bypass the cache and hit live Wikipedia.
# WIKI_CACHE_DIR=
